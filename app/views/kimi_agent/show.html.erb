<h2>🤖 Kimi Agent — полный интерфейс</h2>
<h3><%= @issue.subject.truncate(60) %> (#<%= @issue.id %>)</h3>

<% unless @healthy %>
  <div class="flash warning">
    ⚠️ Kimi Code CLI недоступен (<code><%= Setting.plugin_redmine_kimi_agent['kimi_host'] %>:<%= Setting.plugin_redmine_kimi_agent['kimi_port'] %></code>).
    Убедитесь, что сервер запущен: <code>kimi web</code>
  </div>
<% end %>

<% cf_session = @issue.custom_field_value(@kimi_session_cf).presence rescue nil %>
<% if cf_session.present? %>
  <div class="flash notice">
    🔗 Активная сессия в задаче: <code><%= cf_session.truncate(12) %></code>
  </div>
<% end %>

<div class="box" style="margin-bottom:1em">
  <h4 style="margin-top:0">Управление сессией</h4>
  <%= form_tag({action: :execute}, method: :post) do %>
    <p>
      <label>Рабочая директория (work_dir):</label><br>
      <%= text_field_tag :work_dir,
            Setting.plugin_redmine_kimi_agent['work_dir'],
            size: 60, placeholder: '/home/user/projects/my-project' %>
    </p>
    <p>
      <%= submit_tag '▶ Запустить', class: 'button-positive',
            disabled: !@healthy,
            data: { confirm: 'Запустить Kimi агента для этой задачи?' } %>
      <% if cf_session.present? %>
        <%= link_to '🔄 Продолжить', { action: :resume }, method: :post, class: 'button' %>
        <%= link_to '⛔ Стоп', { action: :stop }, method: :post, class: 'button', data: { confirm: 'Остановить сессию?' } %>
        <%= link_to '🔁 Перезапустить', { action: :restart }, method: :post, class: 'button', data: { confirm: 'Сбросить и запустить новую сессию?' } %>
        <%= link_to '🗑️ Сбросить', { action: :reset }, method: :delete, class: 'button', data: { confirm: 'Очистить session_id из задачи?' } %>
      <% end %>
      <% last_session = @sessions.first %>
      <% if last_session && %w[error stopped].include?(last_session.status) %>
        <%= link_to '📤 Эскалировать менеджеру', { action: :escalate }, method: :post, class: 'button', style: 'background:#fff3cd; color:#856404; border-color:#ffc107', data: { confirm: 'Эскалировать задачу менеджеру?' } %>
      <% end %>
      <%= link_to '🔄 Синхронизировать', { action: :sync }, method: :post, class: 'button' %>
    </p>
  <% end %>

  <details style="margin-top:1em">
    <summary style="cursor:pointer; color:#666">📋 Промпт который будет отправлен агенту</summary>
    <pre style="background:#f5f5f5; padding:1em; font-size:0.85em; max-height:300px; overflow:auto"><%= h @preview_prompt %></pre>
  </details>
</div>

<% if @sessions.any? %>
  <h3>История сессий</h3>
  <table class="list issues">
    <thead>
      <tr>
        <th>Session ID</th>
        <th>Статус</th>
        <th>Пользователь</th>
        <th>Создано</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      <% @sessions.each do |s| %>
        <tr class="<%= cycle('odd', 'even') %>" id="kimi-session-<%= s.id %>">
          <td><code><%= s.session_id.truncate(12) %></code></td>
          <td>
            <span class="kimi-status kimi-status-<%= s.status %>"
                  data-session-db-id="<%= s.id %>"
                  data-status="<%= s.status %>">
              <%= status_icon(s.status) %> <%= s.status %>
            </span>
          </td>
          <td><%= link_to_user s.user %></td>
          <td><%= format_time s.created_at %></td>
          <td>
            <% if %w[running pending].include?(s.status) %>
              <%= link_to '⛔ Отмена',
                    { action: :cancel, id: s.id }, method: :delete,
                    data: { confirm: 'Отменить сессию?' } %>
            <% end %>
            <a href="#" onclick="toggleLog(<%= s.id %>); return false">📄 Лог</a>
            <%= link_to '⬇️ Скачать', { action: :download_log, id: s.id } %>
          </td>
        </tr>
        <tr id="kimi-log-<%= s.id %>" style="display:none">
          <td colspan="5">
            <pre class="kimi-log" id="kimi-log-content-<%= s.id %>" style="background:#1e1e1e; color:#d4d4d4; padding:1em; max-height:400px; overflow:auto; font-size:0.8em; border-radius:4px"><%= h s.result_log.to_s %></pre>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="nodata">Сессий пока нет. Запустите агента из sidebar задачи.</p>
<% end %>

<style>
.kimi-status-done    { color: #2d882d; font-weight: bold }
.kimi-status-running { color: #e67e00; font-weight: bold }
.kimi-status-error   { color: #c0392b; font-weight: bold }
.kimi-status-pending { color: #888 }
.kimi-status-stopped { color: #888; font-weight: bold }
</style>

<script>
function toggleLog(id) {
  var row = document.getElementById('kimi-log-' + id);
  row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
}

document.addEventListener('DOMContentLoaded', function() {
  var active = document.querySelectorAll('[data-status="running"], [data-status="pending"]');
  active.forEach(function(el) {
    var dbId = el.dataset.sessionDbId;
    var interval = setInterval(function() {
      fetch(window.location.pathname + '/' + dbId + '/status')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          el.dataset.status = data.status;
          el.className = 'kimi-status kimi-status-' + data.status;
          el.textContent = data.status;
          var logEl = document.getElementById('kimi-log-content-' + dbId);
          if (logEl && data.result_log) {
            logEl.textContent = data.result_log;
          }
          if (['done', 'idle', 'error', 'stopped'].includes(data.status)) {
            clearInterval(interval);
          }
        });
    }, 3000);
  });
});
</script>
